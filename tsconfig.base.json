{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "strict": true,
    "noEmit": true,
    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
