{
  "name": "@dzhosts/components",
  "version": "0.1.0",
  "description": "Reusable Lit web components for DZHosts applications.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmhobbs/dzhosts-ui.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./alert": {
      "types": "./dist/components/alert.d.ts",
      "import": "./dist/alert.js"
    },
    "./badge": {
      "types": "./dist/components/badge.d.ts",
      "import": "./dist/badge.js"
    },
    "./button": {
      "types": "./dist/components/button.d.ts",
      "import": "./dist/button.js"
    },
    "./checkbox": {
      "types": "./dist/components/checkbox.d.ts",
      "import": "./dist/checkbox.js"
    },
    "./container": {
      "types": "./dist/components/container.d.ts",
      "import": "./dist/container.js"
    },
    "./dialog": {
      "types": "./dist/components/dialog.d.ts",
      "import": "./dist/dialog.js"
    },
    "./divider": {
      "types": "./dist/components/divider.d.ts",
      "import": "./dist/divider.js"
    },
    "./empty-state": {
      "types": "./dist/components/empty-state.d.ts",
      "import": "./dist/empty-state.js"
    },
    "./field": {
      "types": "./dist/components/field.d.ts",
      "import": "./dist/field.js"
    },
    "./grid": {
      "types": "./dist/components/grid.d.ts",
      "import": "./dist/grid.js"
    },
    "./icon-button": {
      "types": "./dist/components/icon-button.d.ts",
      "import": "./dist/icon-button.js"
    },
    "./inline": {
      "types": "./dist/components/inline.d.ts",
      "import": "./dist/inline.js"
    },
    "./input": {
      "types": "./dist/components/input.d.ts",
      "import": "./dist/input.js"
    },
    "./panel": {
      "types": "./dist/components/panel.d.ts",
      "import": "./dist/panel.js"
    },
    "./spinner": {
      "types": "./dist/components/spinner.d.ts",
      "import": "./dist/spinner.js"
    },
    "./stack": {
      "types": "./dist/components/stack.d.ts",
      "import": "./dist/stack.js"
    },
    "./textarea": {
      "types": "./dist/components/textarea.d.ts",
      "import": "./dist/textarea.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly -p tsconfig.json"
  },
  "dependencies": {
    "@dzhosts/tokens": "0.1.0",
    "iconoir": "^7.10.1",
    "lit": "^3.3.0"
  }
}
